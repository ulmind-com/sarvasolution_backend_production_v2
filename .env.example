# ---------------------------------------------------------------------------
# APITxT OTP integration (phone verification on the public registration form)
# Add these to your backend environment (host / Docker / Coolify env), NOT the
# frontend. The auth key stays server-side and is never exposed to browsers.
# ---------------------------------------------------------------------------
APITXT_AUTHKEY=your_apitxt_auth_key
APITXT_BASE_URL=https://apitxt.com/api/sendOTP

# Optional: SMS channel + your pre-approved template id (DLT). If omitted, the
# system default OTP template configured in the APITxT dashboard is used.
# APITXT_CHANNEL=sms
# APITXT_TEMPLATE_ID=42

# Set to "false" to temporarily disable the server-side OTP gate on registration.
# Defaults to enabled (true) when unset.
OTP_VERIFICATION_REQUIRED=true
